{
  "name": "lightweight-blogger",
  "version": "0.0.1",
  "description": "A lightweight, plug-and-play blogging system for static websites with admin dashboard and SEO features",
  "main": "dist/lightweight-blogger.js",
  "module": "dist/lightweight-blogger.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "lightweight-blogger": "./src/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/lightweight-blogger.js",
      "require": "./dist/lightweight-blogger.umd.js"
    }
  },
  "files": [
    "dist",
    "src/cli.js"
  ],
  "scripts": {
    "build": "node build.js",
    "build:umd": "esbuild src/client.js --bundle --format=iife --outfile=dist/lightweight-blogger.umd.js --global-name=LightweightBlogger --minify --platform=browser",
    "build:all": "node build.js && npm run build:umd",
    "generate": "node src/cli.js"
  },
  "devDependencies": {
    "esbuild": "^0.20.0"
  },
  "keywords": [
    "blog",
    "cms",
    "admin",
    "lightweight",
    "static-site",
    "seo",
    "rss",
    "sitemap"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@libsql/client": "^0.6.0",
    "marked": "^12.0.0"
  }
}
